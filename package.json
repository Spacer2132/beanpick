{
  "name": "beanpick",
  "version": "0.1.0",
  "private": true,
  "description": "BeanPick used coffee bean listing manager",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "web": "vite --host 127.0.0.1",
    "electron": "electron .",
    "build": "vite build",
    "pages:prepare": "npm.cmd run build && node scripts/prepare-pages.cjs",
    "package:portable": "node scripts/package-portable.cjs",
    "officialmall:test": "node scripts/test-official-mall.cjs",
    "tasting-notes:test": "node scripts/test-tasting-notes.cjs",
    "smartstore:test": "node scripts/test-smartstore-search.cjs",
    "core-features:test": "node scripts/test-core-features.cjs",
    "history:test": "node scripts/test-history.cjs",
    "iphone-webapp:test": "node scripts/test-iphone-webapp.cjs",
    "dataquality:test": "node scripts/test-data-quality.cjs",
    "verify": "npm.cmd run tasting-notes:test && npm.cmd run officialmall:test && npm.cmd run smartstore:test && npm.cmd run core-features:test && npm.cmd run history:test && npm.cmd run iphone-webapp:test && npm.cmd run dataquality:test && npm.cmd run build && npm.cmd run package:portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.2.0"
  },
  "devDependencies": {}
}
